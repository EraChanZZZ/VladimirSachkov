---
import '../styles/global.css';
import { withBase } from '../base';
const { title, description } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description ?? 'Vladimir Sachkov — machine learning engineer working on 3D vision, LiDAR, and production ML systems.'} />
    <link rel="icon" type="image/svg+xml" href={withBase('/favicon.svg')} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Source+Serif+4:ital,opsz,wght@0,8..60,400;0,8..60,600;0,8..60,700;1,8..60,400&display=swap"
    />
  </head>
  <body>
    <main>
      <slot />
      <footer>
        <p>Vladimir Sachkov · <a href="mailto:vladimirsachkov2003@gmail.com">vladimirsachkov2003@gmail.com</a> · <a href="https://github.com/EraChanZ">GitHub</a> · <a href="https://www.linkedin.com/in/vladimir-sachkov-a3ba2b243">LinkedIn</a></p>
        <p>Русский · English · Nederlands (leer ik nog)</p>
      </footer>
    </main>
  </body>
</html>
