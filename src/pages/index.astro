---
import fs from 'node:fs';
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import { withBase } from '../base';

const projects = (await getCollection('projects')).sort(
  (a, b) => a.data.order - b.data.order
);

// Drop a photo at public/photo.jpg and it appears automatically.
const hasPhoto = fs.existsSync('public/photo.jpg');

const journey = [
  {
    when: 'May 2025 — now',
    what: 'Clear Timber Analytics — ML Engineer',
    detail:
      'Building the ML core of a tree-analysis product, from raw LiDAR point clouds to models to the infrastructure that trains, versions, and serves them. Longest-tenured engineer on the ML team and de-facto product lead: experiment planning, sprint facilitation, end-to-end ML platform ownership.',
  },
  {
    when: 'Nov 2024 — Jan 2025',
    what: 'Bachelor thesis — TU Delft',
    detail:
      'Domain adaptation for hand-landmark detection in infrared imaging, supporting early leprosy screening in Nepal. Graded 9.5/10 for content.',
  },
  {
    when: 'Sep — Oct 2024',
    what: 'Camino de Santiago — Via de la Plata',
    detail:
      'Walked 1,000 km alone from Seville to Santiago de Compostela in five weeks.',
    waypoint: true,
  },
  {
    when: 'Jun — Sep 2024',
    what: 'VisionPlatform — Computer Vision Intern',
    detail:
      'Auto-annotation pipeline built on an ensemble of open-vocabulary vision-language models; multi-GPU inference serving.',
  },
  {
    when: '2022 — 2025',
    what: 'TU Delft — BSc Computer Science, cum laude',
    detail:
      'GPA 8.1/10. Minor in Quantum Science & Quantum Information; 10/10 in Mathematical Analysis from the maths bachelor. Founded the programming-contest committee.',
  },
  {
    when: '2022 — 2023',
    what: 'BasisHealth — Backend Developer',
    detail:
      'Go microservices on Kubernetes, bidirectional gRPC streaming, Jenkins CI/CD — alongside full-time study.',
  },
  {
    when: '2021 — 2022',
    what: 'University of Groningen — Computing Science',
    detail: 'First year at GPA 9.35/10, then transferred to TU Delft.',
  },
  {
    when: '2019 — 2021',
    what: 'Moscow — IB Diploma',
    detail:
      '80% merit scholarship for IT competitions and organizing CS events. Eight-time participant of the GoTo programming camp; 2nd place at the national AI-Academy Olympiad.',
  },
];
---

<Base title="Vladimir Sachkov">
  <section class="hero">
    <div class="hero-text">
      <h1>Vladimir Sachkov</h1>
      <p class="tagline">Machine learning engineer — 3D vision, LiDAR, production ML</p>
      <p class="meta">
        Utrecht, Netherlands · <a href="https://github.com/EraChanZ">GitHub</a> ·
        <a href="https://www.linkedin.com/in/vladimir-sachkov-a3ba2b243">LinkedIn</a> ·
        <a href="mailto:vladimirsachkov2003@gmail.com">Email</a>
      </p>
    </div>
    {
      hasPhoto ? (
        <img class="portrait" src={withBase('/photo.jpg')} alt="Vladimir Sachkov" />
      ) : (
        <div class="portrait portrait-placeholder">VS</div>
      )
    }
  </section>

  <h2>About</h2>
  <p>
    I build machine learning systems end-to-end. At
    <a href="https://cleartimber.com">Clear Timber Analytics</a> I own the ML core of a
    tree-analysis product: 3D instance segmentation on very large LiDAR point clouds, the
    C/C++-accelerated processing library underneath it, and the MLOps platform around it
    — where a single YAML file configures a fully tracked, reproducible training run on
    versioned data.
  </p>
  <p>
    A model is only interesting to me once it survives contact with production. That
    conviction runs through everything here: research that ships, infrastructure that
    lets a small team move fast, and enough product ownership to know <em>why</em> a
    metric matters before improving it.
  </p>
  <p>
    The route was Moscow → Groningen → Delft, picking up a quantum-information minor, a
    medical-imaging thesis, a habit of founding and teaching things — and, once, a
    thousand-kilometre walk across Spain.
  </p>

  <h2>Journey</h2>
  <ol class="timeline">
    {
      journey.map((step) => (
        <li class:list={[{ waypoint: step.waypoint }]}>
          <span class="when meta">{step.when}</span>
          <span class="what">{step.what}</span>
          <p class="detail">{step.detail}</p>
        </li>
      ))
    }
  </ol>

  <h2>Selected projects</h2>
  <div class="projects">
    {
      projects.map((p) => (
        <a class="project-card" href={withBase(`/projects/${p.id}/`)}>
          <div class="head">
            <h3>{p.data.title}</h3>
            <span class="meta">{p.data.period}</span>
          </div>
          <p class="tagline">{p.data.tagline}</p>
          <div class="tag-row">
            {p.data.tags.map((t) => (
              <span class="tag">{t}</span>
            ))}
          </div>
        </a>
      ))
    }
  </div>

  <h2>Hackathons, community &amp; teaching</h2>
  <p>
    Hackathons are where I practise the parts of the job that aren't code: forming an
    idea under ambiguity, aligning a team of strangers on an architecture in the first
    hour, and shipping a demo that tells the story. A sample:
  </p>
  <ul>
    <li>
      <strong>🏆 Best Dify Workflow Integration — &#123;Tech: Europe&#125; Paris AI Hack</strong>
      (2026). <em>NestAI</em>, an agent that answers "where should I live?" — neighborhood
      amenity scoring, live listings, a custom OpenStreetMap plugin, multilingual UI.
    </li>
    <li>
      <strong>Physical AI Hackathon (Google DeepMind × IBM × Arke), Zurich</strong>
      (2026). A factory production scheduler: Earliest-Deadline-First planning plus an LLM
      layer for plain-English operator commands, with camera-driven defect detection that
      reschedules the line in real time.
    </li>
    <li>
      <strong>🏆 2nd place, bunq Financial API Hackathon</strong> (2025) — LLM-driven
      simulation engine for testing banking scenarios in natural language.
    </li>
    <li>
      <strong>Founder, university programming-contest committee</strong> — organized
      contests, wrote problem sets, and ran training sessions.
      <strong>GoTo camp</strong> (Russia's largest competitive-programming camp):
      eight-time participant, twice a junior teacher.
    </li>
    <li>
      <strong>🏆 3rd place, 38th Classic CloudDelight Coding Contest</strong>, Amsterdam
      (2023); <strong>2nd place, AI-Academy Olympiad</strong>, Russia (2021).
    </li>
  </ul>

  <h2>Skills</h2>
  <dl class="skills-table">
    <dt>Languages</dt>
    <dd>Python (expert), C/C++ (pybind11, CPython extensions), Go, SQL, JavaScript</dd>
    <dt>ML &amp; numerics</dt>
    <dd>PyTorch (+ Lightning), FlashAttention, transformers, scikit-learn, NumPy, SciPy</dd>
    <dt>Systems &amp; MLOps</dt>
    <dd>Azure DevOps, MLflow, DVC, Docker, Kubernetes, gRPC, REST, PostgreSQL, Redis, Linux</dd>
  </dl>
</Base>
